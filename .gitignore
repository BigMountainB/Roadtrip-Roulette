node_modules/
dist/
.DS_Store
*.log
.vite/
ios/App/Pods/
ios/App/build/
# Capacitor's auto-generated copy of dist/ (regenerated by `cap sync`)
ios/App/App/public/

# Working / scratch dirs (not used by build)
tmp/
Archive/

# Duplicate package-lock created by some npm runs
package-lock 2.json

# Local assets sources kept outside the build path.
# Anchored to root with leading slash so macOS's case-insensitive
# filesystem doesn't accidentally swallow `public/assets/music/`
# (the deployed-into-the-game MP3 folder) via case-folded match.
/Music/
Images/Codex_Concepts/

# Local Cloudflare deploy secrets — never commit (sourced by scripts/deploy.sh)
.cloudflare.env
.dev.vars
